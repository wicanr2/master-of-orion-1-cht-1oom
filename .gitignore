# === 引擎本體:不入庫,只放 patch ===
# 1oom 為本機參考 clone(保留自身 .git 以便 diff 上游產 patch)
/1oom/

# === 版權原始素材:絕不入庫 ===
*.rar
*.zip
/assets/game/
# CJK 字型若為授權字型,確認授權後再決定是否放行
/assets/fonts/*.ttf
/assets/fonts/*.otf

# === 暫存與建置產物 ===
/tmp_*/
*.tmp
/build/
*.o
*.a
*.AppImage

# 編輯器 / 系統
.DS_Store
*.swp

# 測試用 atlas(throwaway)
/assets/fonts/*_test.bin
/build/
/build-asan/
# 跨平台交叉編譯產物(build-win / build-mac / build-lin …)
/build-*/

# 萃取工具 stderr
*.err

# 打包產物(含版權資料,不入庫)
/release/
/dist-all/
/build/bundle_data/

# Claude 專案記憶副本 + dev-setup 包(僅本機/可攜,不入庫)
/claude-context/
*-dev-setup.tar.gz
