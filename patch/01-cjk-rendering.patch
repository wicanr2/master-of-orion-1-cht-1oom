+/* CJK(繁中)支援:字串以 UTF-8 編碼,CJK 走 cjkfont atlas。
+   MOO 控制碼都 < 0x20,UTF-8 前導位元組 >= 0xC0,不衝突。
+   見 docs/adr/0001 與 rules/81-retro-cjk-hires-canvas。 */
+
+/* 解 str 起點的 3-byte UTF-8(涵蓋 U+0800..U+FFFF,含 CJK/全形)。
+   非 3-byte 序列回 0;成功回碼點。 */
+static uint32_t lbxfont_utf8_decode3(const char *str)
+{
+    uint8_t b0 = (uint8_t)str[0];
+    if (b0 < 0xe0 || b0 > 0xef) {
+        return 0;
+    }
+    uint8_t b1 = (uint8_t)str[1];
+    uint8_t b2 = (uint8_t)str[2];
+    if ((b1 & 0xc0) != 0x80 || (b2 & 0xc0) != 0x80) {
+        return 0;
+    }
+    return ((uint32_t)(b0 & 0x0f) << 12) | ((uint32_t)(b1 & 0x3f) << 6) | (uint32_t)(b2 & 0x3f);
+}
+
+/* 若 str 起點是已收錄的 CJK 碼點,回該碼點,否則 0。 */
+static uint32_t lbxfont_cjk_at(const char *str)
+{
+    uint32_t cp = lbxfont_utf8_decode3(str);
+    return (cp && cjkfont_has(cp)) ? cp : 0;
+}
+
+/* CJK 在 320×200 邏輯下的前進寬度。
+   影像層在 2× 合成層(640×400)以 CJK 尺寸(24/16/14,依字型高度)畫出,
+   故邏輯前進 = cjk_size / 2,使相鄰字在合成層恰好相接、不重疊不留縫。 */
+#define CJK_LOGICAL_SCALE 2
+static int lbxfont_cjk_advance(void)
+{
+    if (cjkfont_glyph_w() <= 0) {
+        return 0;
+    }
+    return cjkfont_size_for(lbxfontdata[0x10]) / CJK_LOGICAL_SCALE;
+}
+
+/* 處理字串第 i 位的 CJK:推進 *xp,主畫面 pass(record=true)時記進 draw-list
+   供影像層在高解析合成層畫出。回傳 true 表示已吃掉一個 CJK(3 bytes)。 */
+static bool lbxfont_handle_cjk(const char *str, int *xp, int y, uint32_t cp, bool record)
+{
+    if (record) {
+        /* 字色取目前字型漸層最高亮端(0x0f);影像層另加黑外框 + 太暗自動提亮確保對比。 */
+        cjk_drawlist_add(*xp, y, cp, lbxfontdata[0x0f], lbxfontdata[0x10]);
+    }
+    *xp += lbxfont_cjk_advance();
+    (void)str;
+    return true;
+}
