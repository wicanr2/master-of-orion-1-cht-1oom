+   回傳前進寬度(glyph 寬 + gap)。 */
+static int lbxfont_plot_cjk(int x, int y, uint32_t cp)
+{
+    int gw = 0, gh = 0;
+    const uint8_t *g = cjkfont_get(cp, &gw, &gh);
+    if (!g) {
