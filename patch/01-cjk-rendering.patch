@@ -0,0 +1,25 @@
+#ifndef INC_1OOM_CJKFONT_H
+#define INC_1OOM_CJKFONT_H
+
+#include "types.h"
+
+/* CJK 點陣 atlas(由 tools/build_cjk_font.py 產生,magic "MOOCJK\0\1")。
+   繁中化用:lbxfont 在字串迴圈遇到 UTF-8 CJK 碼點時,改用本模組的 glyph 渲染。
+   詳見 docs/adr/0001 與 rules/81-retro-cjk-hires-canvas。 */
+
+/* 從 path 載入 atlas;path 為 NULL 時讀環境變數 MOO_CJK_FONT。
+   成功回傳 true。重複呼叫安全(先釋放舊的)。 */
+extern bool cjkfont_init(const char *path);
+extern void cjkfont_shutdown(void);
+
+/* atlas 是否已載入且有任一字。 */
+extern bool cjkfont_available(void);
+
+/* 取得 cp 的 glyph alpha(gw*gh bytes,0..255);找不到回 NULL。
+   *w / *h 回填 glyph 尺寸(可為 NULL)。 */
+extern const uint8_t *cjkfont_get(uint32_t cp, int *w, int *h);
+
+/* 便利:cp 是否在 atlas 內。 */
+extern bool cjkfont_has(uint32_t cp);
+
+#endif
