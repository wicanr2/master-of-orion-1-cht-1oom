diff --git a/src/cjkfont.c b/src/cjkfont.c
new file mode 100644
index 0000000..058278b
--- /dev/null
+++ b/src/cjkfont.c
@@ -0,0 +1,189 @@
+#include "config.h"
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+
+#include "cjkfont.h"
+#include "lib.h"
+#include "log.h"
+
+/* atlas 檔格式(little endian):
+     magic[8] "MOOCJK\0\1"
+     u16 glyphW, u16 glyphH, u32 count
+     count * { u32 codepoint ; glyphW*glyphH bytes alpha }
+   codepoint 升序排列 -> 二分查找。 */
+
+static const char CJK_MAGIC[8] = { 'M','O','O','C','J','K','\0','\1' };
+
+static struct {
+    uint8_t *raw;        /* 整檔 buffer */
+    int w, h;            /* glyph 尺寸 */
+    uint32_t count;
+    int recsz;           /* 4 + w*h */
+    const uint8_t *recs; /* 指向第一筆 record */
+} cjk = { 0 };
+
+static uint32_t rec_cp(int i)
+{
+    const uint8_t *p = cjk.recs + (size_t)i * cjk.recsz;
+    return (uint32_t)p[0] | ((uint32_t)p[1] << 8) | ((uint32_t)p[2] << 16) | ((uint32_t)p[3] << 24);
+}
+
+bool cjkfont_init(const char *path)
+{
+    cjkfont_shutdown();
+    if (!path) {
+        path = getenv("MOO_CJK_FONT");
+    }
+    if (!path || !path[0]) {
+        return false;
+    }
+    FILE *f = fopen(path, "rb");
+    if (!f) {
+        log_warning("CJK: cannot open font '%s'\n", path);
+        return false;
+    }
+    fseek(f, 0, SEEK_END);
+    long len = ftell(f);
+    fseek(f, 0, SEEK_SET);
+    if (len < 16) {
+        fclose(f);
+        return false;
+    }
+    uint8_t *raw = lib_malloc(len);
+    if (fread(raw, 1, len, f) != (size_t)len) {
+        fclose(f);
+        lib_free(raw);
+        return false;
+    }
+    fclose(f);
+
+    if (memcmp(raw, CJK_MAGIC, 8) != 0) {
+        log_warning("CJK: bad magic in '%s'\n", path);
+        lib_free(raw);
+        return false;
+    }
+    int w = raw[8] | (raw[9] << 8);
+    int h = raw[10] | (raw[11] << 8);
+    uint32_t count = (uint32_t)raw[12] | ((uint32_t)raw[13] << 8) | ((uint32_t)raw[14] << 16) | ((uint32_t)raw[15] << 24);
+    int recsz = 4 + w * h;
+    if (w <= 0 || h <= 0 || (long)(16 + (long)count * recsz) > len) {
+        log_warning("CJK: corrupt header in '%s'\n", path);
+        lib_free(raw);
+        return false;
+    }
+    cjk.raw = raw;
+    cjk.w = w;
+    cjk.h = h;
+    cjk.count = count;
+    cjk.recsz = recsz;
+    cjk.recs = raw + 16;
+    log_message("CJK: loaded %u glyphs %dx%d from '%s'\n", count, w, h, path);
+    return true;
+}
+
+void cjkfont_shutdown(void)
+{
+    if (cjk.raw) {
+        lib_free(cjk.raw);
+    }
+    memset(&cjk, 0, sizeof(cjk));
+}
+
+bool cjkfont_available(void)
+{
+    return cjk.raw && cjk.count;
+}
+
+const uint8_t *cjkfont_get(uint32_t cp, int *w, int *h)
+{
+    if (!cjk.raw || cjk.count == 0) {
+        return NULL;
+    }
+    int lo = 0, hi = (int)cjk.count - 1;
+    while (lo <= hi) {
+        int mid = (lo + hi) >> 1;
+        uint32_t c = rec_cp(mid);
+        if (c == cp) {
+            if (w) { *w = cjk.w; }
+            if (h) { *h = cjk.h; }
+            return cjk.recs + (size_t)mid * cjk.recsz + 4;
+        } else if (c < cp) {
+            lo = mid + 1;
+        } else {
+            hi = mid - 1;
+        }
+    }
+    return NULL;
+}
+
+bool cjkfont_has(uint32_t cp)
+{
+    return cjkfont_get(cp, NULL, NULL) != NULL;
+}
+
+int cjkfont_size_for(int fonth)
+{
+    /* 原版字高 ->; CJK 尺寸:>=10 大字(選單/標題)24;8-9 中 16;其餘密集小字 14。 */
+    if (fonth >= 10) {
+        return 24;
+    } else if (fonth >= 8) {
+        return 16;
+    }
+    return 14;
+}
+
+int cjkfont_glyph_w(void)
+{
+    return cjk.w;
+}
+
+int cjkfont_glyph_h(void)
+{
+    return cjk.h;
+}
+
+/* ---- CJK draw-list ---- */
+
+#define CJK_DRAWLIST_MAX 4096
+static cjk_draw_t cjk_lists[2][CJK_DRAWLIST_MAX];
+static int cjk_n[2] = { 0, 0 };
+static int cjk_front = 0;    /* present 讀此頁;append 寫 pending = 1 - front */
+
+void cjk_drawlist_add(int x, int y, uint32_t cp, uint8_t color, uint8_t fonth)
+{
+    int b = 1 - cjk_front;
+    if (cjk_n[b] >= CJK_DRAWLIST_MAX) {
+        return;
+    }
+    cjk_draw_t *d = &cjk_lists[b][cjk_n[b]++];
+    d->x = (int16_t)x;
+    d->y = (int16_t)y;
+    d->cp = cp;
+    d->color = color;
+    d->fonth = fonth;
+}
+
+void cjk_drawlist_flip(void)
+{
+    /* pending(剛畫好)成為 front;新的 pending 清空待下一 frame。 */
+    cjk_front = 1 - cjk_front;
+    cjk_n[1 - cjk_front] = 0;
+}
+
+void cjk_drawlist_clear(void)
+{
+    cjk_n[0] = 0;
+    cjk_n[1] = 0;
+}
+
+int cjk_drawlist_count(void)
+{
+    return cjk_n[cjk_front];
+}
+
+const cjk_draw_t *cjk_drawlist_get(int i)
+{
+    return ((i >= 0) && (i < cjk_n[cjk_front])) ? &cjk_lists[cjk_front][i] : NULL;
+}
diff --git a/src/cjkfont.h b/src/cjkfont.h
new file mode 100644
index 0000000..bc41829
--- /dev/null
+++ b/src/cjkfont.h
@@ -0,0 +1,56 @@
+#ifndef INC_1OOM_CJKFONT_H
+#define INC_1OOM_CJKFONT_H
+
+#include "types.h"
+
+/* CJK 點陣 atlas(由 tools/build_cjk_font.py 產生,magic "MOOCJK\0\1")。
+   繁中化用:lbxfont 在字串迴圈遇到 UTF-8 CJK 碼點時,改用本模組的 glyph 渲染。
+   詳見 docs/adr/0001 與 rules/81-retro-cjk-hires-canvas。 */
+
+/* 從 path 載入 atlas;path 為 NULL 時讀環境變數 MOO_CJK_FONT。
+   成功回傳 true。重複呼叫安全(先釋放舊的)。 */
+extern bool cjkfont_init(const char *path);
+extern void cjkfont_shutdown(void);
+
+/* atlas 是否已載入且有任一字。 */
+extern bool cjkfont_available(void);
+
+/* 取得 cp 的 glyph alpha(gw*gh bytes,0..255);找不到回 NULL。
+   *w / *h 回填 glyph 尺寸(可為 NULL)。 */
+extern const uint8_t *cjkfont_get(uint32_t cp, int *w, int *h);
+
+/* 便利:cp 是否在 atlas 內。 */
+extern bool cjkfont_has(uint32_t cp);
+
+/* glyph 尺寸(atlas cell 邊長);未載入回 0。 */
+extern int cjkfont_glyph_w(void);
+extern int cjkfont_glyph_h(void);
+
+/* 依原版字型高度 fonth 選 CJK 渲染尺寸(24/16/14)。
+   密集面板用矮字型 -> 小 CJK,避免緊湊版面破版。lbxfont(前進寬)與
+   影像層(繪製尺寸)共用此函式,確保一致。 */
+extern int cjkfont_size_for(int fonth);
+
+/* ---- CJK draw-list ----
+   lbxfont 在 320×200 邏輯座標遇到 CJK 時不直接畫進 vgabuf,而是把
+   (x, y, codepoint, 調色盤色號) 記進此 list;影像層在 present 時於
+   高解析合成層(640×400)以 24×24 + 外框畫出。每個 present frame 清空。
+   見 docs/adr/0001 與 rules/81-retro-cjk-hires-canvas。 */
+typedef struct cjk_draw_s {
+    int16_t x, y;       /* 320×200 邏輯座標(glyph 左、文字行頂) */
+    uint8_t color;      /* 調色盤索引(由 lbxfont 目前字色決定) */
+    uint8_t fonth;      /* 當下原版字高,供垂直對齊 */
+    uint32_t cp;        /* Unicode 碼點 */
+} cjk_draw_t;
+
+/* draw-list 與 vgabuf 一樣 double-buffer 並綁 page flip:
+   lbxfont append 到 pending;vgabuf_flip 時呼叫 cjk_drawlist_flip 把 pending
+   換成 front 並清空新的 pending。present(含 delay 重複 present)讀 front。
+   如此 delay 期間重複 present 不會讓 CJK 消失。 */
+extern void cjk_drawlist_add(int x, int y, uint32_t cp, uint8_t color, uint8_t fonth);
+extern void cjk_drawlist_flip(void);   /* 由 vgabuf_flip 呼叫 */
+extern void cjk_drawlist_clear(void);  /* 全清(reset/shutdown) */
+extern int cjk_drawlist_count(void);   /* front 數量(供 present) */
+extern const cjk_draw_t *cjk_drawlist_get(int i); /* front 第 i 筆 */
+
+#endif
diff --git a/src/hw/sdl/2/hwsdl2_video.c b/src/hw/sdl/2/hwsdl2_video.c
index eb679c7..d486e58 100644
--- a/src/hw/sdl/2/hwsdl2_video.c
+++ b/src/hw/sdl/2/hwsdl2_video.c
@@ -7,6 +7,7 @@
 
 #include "hw.h"
 #include "hw_internal.h"
