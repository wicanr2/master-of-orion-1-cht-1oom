+        int py = oy + j;
+        if (py < 0 || py >= VGABUF_H) {
+            continue;
+        }
+        for (int k = 0; k < gw; ++k) {
+            int px = x + k;
+            if (px < 0 || px >= VGABUF_W) {
+                continue;
+            }
+            uint8_t a = g[j * gw + k];
+            if (a < 0x20) {
