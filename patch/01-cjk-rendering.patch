diff --git a/src/cjkfont.c b/src/cjkfont.c
new file mode 100644
index 0000000..322b378
--- /dev/null
+++ b/src/cjkfont.c
@@ -0,0 +1,124 @@
+#include "config.h"
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+
+#include "cjkfont.h"
+#include "lib.h"
+#include "log.h"
+
+/* atlas 檔格式(little endian):
+     magic[8] "MOOCJK\0\1"
+     u16 glyphW, u16 glyphH, u32 count
+     count * { u32 codepoint ; glyphW*glyphH bytes alpha }
+   codepoint 升序排列 -> 二分查找。 */
+
+static const char CJK_MAGIC[8] = { 'M','O','O','C','J','K','\0','\1' };
+
+static struct {
+    uint8_t *raw;        /* 整檔 buffer */
+    int w, h;            /* glyph 尺寸 */
+    uint32_t count;
+    int recsz;           /* 4 + w*h */
+    const uint8_t *recs; /* 指向第一筆 record */
+} cjk = { 0 };
+
+static uint32_t rec_cp(int i)
+{
+    const uint8_t *p = cjk.recs + (size_t)i * cjk.recsz;
+    return (uint32_t)p[0] | ((uint32_t)p[1] << 8) | ((uint32_t)p[2] << 16) | ((uint32_t)p[3] << 24);
+}
+
+bool cjkfont_init(const char *path)
+{
+    cjkfont_shutdown();
+    if (!path) {
+        path = getenv("MOO_CJK_FONT");
+    }
+    if (!path || !path[0]) {
+        return false;
+    }
+    FILE *f = fopen(path, "rb");
+    if (!f) {
+        log_warning("CJK: cannot open font '%s'\n", path);
+        return false;
+    }
+    fseek(f, 0, SEEK_END);
+    long len = ftell(f);
+    fseek(f, 0, SEEK_SET);
+    if (len < 16) {
+        fclose(f);
+        return false;
+    }
+    uint8_t *raw = lib_malloc(len);
+    if (fread(raw, 1, len, f) != (size_t)len) {
+        fclose(f);
+        lib_free(raw);
+        return false;
+    }
+    fclose(f);
+
+    if (memcmp(raw, CJK_MAGIC, 8) != 0) {
+        log_warning("CJK: bad magic in '%s'\n", path);
+        lib_free(raw);
+        return false;
+    }
+    int w = raw[8] | (raw[9] << 8);
+    int h = raw[10] | (raw[11] << 8);
+    uint32_t count = (uint32_t)raw[12] | ((uint32_t)raw[13] << 8) | ((uint32_t)raw[14] << 16) | ((uint32_t)raw[15] << 24);
+    int recsz = 4 + w * h;
+    if (w <= 0 || h <= 0 || (long)(16 + (long)count * recsz) > len) {
+        log_warning("CJK: corrupt header in '%s'\n", path);
+        lib_free(raw);
+        return false;
+    }
+    cjk.raw = raw;
+    cjk.w = w;
+    cjk.h = h;
+    cjk.count = count;
+    cjk.recsz = recsz;
+    cjk.recs = raw + 16;
+    log_message("CJK: loaded %u glyphs %dx%d from '%s'\n", count, w, h, path);
+    return true;
+}
+
+void cjkfont_shutdown(void)
+{
+    if (cjk.raw) {
+        lib_free(cjk.raw);
+    }
+    memset(&cjk, 0, sizeof(cjk));
+}
+
+bool cjkfont_available(void)
+{
+    return cjk.raw && cjk.count;
+}
+
+const uint8_t *cjkfont_get(uint32_t cp, int *w, int *h)
+{
+    if (!cjk.raw || cjk.count == 0) {
+        return NULL;
+    }
+    int lo = 0, hi = (int)cjk.count - 1;
+    while (lo <= hi) {
+        int mid = (lo + hi) >> 1;
+        uint32_t c = rec_cp(mid);
+        if (c == cp) {
+            if (w) { *w = cjk.w; }
+            if (h) { *h = cjk.h; }
+            return cjk.recs + (size_t)mid * cjk.recsz + 4;
+        } else if (c < cp) {
+            lo = mid + 1;
+        } else {
+            hi = mid - 1;
+        }
+    }
+    return NULL;
+}
+
+bool cjkfont_has(uint32_t cp)
+{
+    return cjkfont_get(cp, NULL, NULL) != NULL;
+}
