 #include "comp.h"
 #include "hwsdl_video.h"
 #include "hwsdl_opt.h"
@@ -251,6 +252,122 @@ static void video_adjust_window_size(int *wptr, int *hptr)
     *hptr = h;
 }
 
+/* ---- CJK 高解析合成層 ----
+   把 320×200 遊戲 2× nearest 放大到 640×400 合成層,CJK 以原尺寸(如 24×24)
+   + 黑外框畫上去,再整層縮放到視窗。底圖 = pixel scaling;CJK = 真 24×24。
+   見 docs/adr/0001 與 rules/81-retro-cjk-hires-canvas。 */
+#define CJK_SCALE 2
+#define CJK_CACHE_N 2048
+
+static struct {
+    SDL_Texture *composite;
+    int cw, ch;
+    struct { uint32_t cp; SDL_Texture *tex; } cache[CJK_CACHE_N];
+    int gw, gh;
+} cjkv = { 0 };
+
+static SDL_Texture *cjk_glyph_tex(uint32_t cp)
+{
+    int gw = cjkfont_glyph_w(), gh = cjkfont_glyph_h();
+    if (gw <= 0 || gh <= 0) {
+        return NULL;
+    }
+    if (cjkv.gw != gw || cjkv.gh != gh) {
+        for (int i = 0; i < CJK_CACHE_N; ++i) {
+            if (cjkv.cache[i].tex) { SDL_DestroyTexture(cjkv.cache[i].tex); }
+        }
+        memset(cjkv.cache, 0, sizeof(cjkv.cache));
+        cjkv.gw = gw;
+        cjkv.gh = gh;
+    }
+    unsigned h0 = (cp * 2654435761u) & (CJK_CACHE_N - 1);
+    for (unsigned i = 0; i < CJK_CACHE_N; ++i) {
+        unsigned idx = (h0 + i) & (CJK_CACHE_N - 1);
+        if (cjkv.cache[idx].tex) {
+            if (cjkv.cache[idx].cp == cp) {
+                return cjkv.cache[idx].tex;
+            }
+            continue;
+        }
+        const uint8_t *a = cjkfont_get(cp, NULL, NULL);
+        if (!a) {
+            return NULL;
+        }
+        SDL_Texture *t = SDL_CreateTexture(video.renderer, SDL_PIXELFORMAT_ARGB8888, SDL_TEXTUREACCESS_STATIC, gw, gh);
+        if (!t) {
+            return NULL;
+        }
+        uint32_t *px = lib_malloc(gw * gh * 4);
+        for (int p = 0; p < gw * gh; ++p) {
+            px[p] = ((uint32_t)a[p] << 24) | 0x00ffffffu; /* ARGB: 白色 + atlas alpha */
+        }
+        SDL_UpdateTexture(t, NULL, px, gw * 4);
+        lib_free(px);
+        SDL_SetTextureBlendMode(t, SDL_BLENDMODE_BLEND);
+        SDL_SetTextureScaleMode(t, SDL_ScaleModeLinear); /* 縮小到 16/14 時較平滑 */
+        cjkv.cache[idx].cp = cp;
+        cjkv.cache[idx].tex = t;
+        return t;
+    }
+    return NULL;
+}
+
+static bool cjk_ensure_composite(void)
+{
+    int cw = video.screen.buffer->w * CJK_SCALE;
+    int ch = video.screen.buffer->h * CJK_SCALE;
+    if (cjkv.composite && (cjkv.cw != cw || cjkv.ch != ch)) {
+        SDL_DestroyTexture(cjkv.composite);
+        cjkv.composite = NULL;
+    }
+    if (!cjkv.composite) {
+        cjkv.composite = SDL_CreateTexture(video.renderer, SDL_PIXELFORMAT_ARGB8888, SDL_TEXTUREACCESS_TARGET, cw, ch);
+        if (!cjkv.composite) {
+            return false;
+        }
+        cjkv.cw = cw;
+        cjkv.ch = ch;
+    }
+    return true;
+}
+
+/* render target 須已是 composite。把 drawlist 的 CJK 畫上去(黑外框 + 字色)。 */
+static void cjk_draw_overlay(void)
+{
+    static const int ox[8] = { -1, 1, 0, 0, -1, 1, -1, 1 };
+    static const int oy[8] = { 0, 0, -1, 1, -1, -1, 1, 1 };
+    int n = cjk_drawlist_count();
+    for (int i = 0; i < n; ++i) {
+        const cjk_draw_t *d = cjk_drawlist_get(i);
+        SDL_Texture *t = cjk_glyph_tex(d->cp);
+        if (!t) {
+            continue;
+        }
+        /* 依原版字型高度選 CJK 尺寸(24/16/14);24-atlas glyph 由 SDL 縮放至此尺寸。 */
+        int sz = cjkfont_size_for(d->fonth);
+        SDL_Rect dst;
+        dst.w = sz;
+        dst.h = sz;
+        dst.x = d->x * CJK_SCALE;
+        dst.y = (d->y + d->fonth) * CJK_SCALE - sz; /* 貼齊文字行底 */
+        SDL_SetTextureColorMod(t, 0, 0, 0);
+        for (int k = 0; k < 8; ++k) {
+            SDL_Rect o = dst;
+            o.x += ox[k];
+            o.y += oy[k];
+            SDL_RenderCopy(video.renderer, t, NULL, &o);
+        }
+        SDL_Color c = video.color[d->color];
+        /* 對比保底:字色太暗時提亮到近白,確保在任何背景上可讀。 */
+        int lum = (c.r * 30 + c.g * 59 + c.b * 11) / 100;
+        if (lum < 110) {
+            c.r = c.g = c.b = 235;
+        }
+        SDL_SetTextureColorMod(t, c.r, c.g, c.b);
+        SDL_RenderCopy(video.renderer, t, NULL, &dst);
+    }
+}
+
 static void video_update(void)
 {
     if (!video.screen_visible) {
@@ -295,7 +412,19 @@ static void video_update(void)
     /* Make sure the pillarboxes are kept clear each frame. */
     SDL_RenderClear(video.renderer);
 
-    if (hw_opt_smooth_pixel_scaling && (video.screen.texture_upscaled != NULL)) {
+    if ((cjk_drawlist_count() > 0) && cjk_ensure_composite()) {
+        /* 有 CJK:走 640×400 合成層。logical size 暫關以對 target 全幅繪製,事後還原。 */
+        int lw = 0, lh = 0;
+        SDL_RenderGetLogicalSize(video.renderer, &lw, &lh);
+        SDL_RenderSetLogicalSize(video.renderer, 0, 0);
+        SDL_SetRenderTarget(video.renderer, cjkv.composite);
+        SDL_RenderCopy(video.renderer, video.screen.texture, NULL, NULL); /* 320×200 -> 640×400 nearest */
+        cjk_draw_overlay();
+        SDL_SetRenderTarget(video.renderer, NULL);
+        SDL_RenderSetLogicalSize(video.renderer, lw, lh);
+        SDL_RenderClear(video.renderer);
+        SDL_RenderCopy(video.renderer, cjkv.composite, NULL, NULL); /* 640×400 -> 視窗(維持比例) */
+    } else if (hw_opt_smooth_pixel_scaling && (video.screen.texture_upscaled != NULL)) {
         /* Render this intermediate texture into the upscaled texture
            using "nearest" integer scaling.
         */
@@ -325,6 +454,8 @@ static void video_update(void)
 
     /* Draw! */
     SDL_RenderPresent(video.renderer);
+    /* 注意:draw-list 不在此清空;它隨 vgabuf_flip 換頁(cjk_drawlist_flip),
+       使 delay 期間的重複 present 仍讀得到 front list。 */
 }
 
 static void video_setpal(const uint8_t *pal, int first, int num)
diff --git a/src/lbxfont.c b/src/lbxfont.c
index 8ae1b61..ba9d3b4 100644
--- a/src/lbxfont.c
+++ b/src/lbxfont.c
@@ -5,6 +5,8 @@
 
 #include "lbxfont.h"
 #include "bits.h"
+#include "cjkfont.h"
+#include "strtr.h"
 #include "lib.h"
 #include "lbx.h"
 #include "lbxpal.h"
@@ -46,6 +48,58 @@ static uint16_t lbxfont_tbl_split_hmm4[4] = { 0, 0, 0, 0 };
 
 /* -------------------------------------------------------------------------- */
 
+/* CJK(繁中)支援:字串以 UTF-8 編碼,CJK 走 cjkfont atlas。
+   MOO 控制碼都 < 0x20,UTF-8 前導位元組 >= 0xC0,不衝突。
+   見 docs/adr/0001 與 rules/81-retro-cjk-hires-canvas。 */
+
+/* 解 str 起點的 3-byte UTF-8(涵蓋 U+0800..U+FFFF,含 CJK/全形)。
+   非 3-byte 序列回 0;成功回碼點。 */
+static uint32_t lbxfont_utf8_decode3(const char *str)
+{
+    uint8_t b0 = (uint8_t)str[0];
+    if (b0 < 0xe0 || b0 > 0xef) {
+        return 0;
+    }
+    uint8_t b1 = (uint8_t)str[1];
+    uint8_t b2 = (uint8_t)str[2];
+    if ((b1 & 0xc0) != 0x80 || (b2 & 0xc0) != 0x80) {
+        return 0;
+    }
+    return ((uint32_t)(b0 & 0x0f) << 12) | ((uint32_t)(b1 & 0x3f) << 6) | (uint32_t)(b2 & 0x3f);
+}
+
+/* 若 str 起點是已收錄的 CJK 碼點,回該碼點,否則 0。 */
+static uint32_t lbxfont_cjk_at(const char *str)
+{
+    uint32_t cp = lbxfont_utf8_decode3(str);
+    return (cp && cjkfont_has(cp)) ? cp : 0;
+}
+
+/* CJK 在 320×200 邏輯下的前進寬度。
+   影像層在 2× 合成層(640×400)以 CJK 尺寸(24/16/14,依字型高度)畫出,
+   故邏輯前進 = cjk_size / 2,使相鄰字在合成層恰好相接、不重疊不留縫。 */
+#define CJK_LOGICAL_SCALE 2
+static int lbxfont_cjk_advance(void)
+{
+    if (cjkfont_glyph_w() <= 0) {
+        return 0;
+    }
+    return cjkfont_size_for(lbxfontdata[0x10]) / CJK_LOGICAL_SCALE;
+}
+
+/* 處理字串第 i 位的 CJK:推進 *xp,主畫面 pass(record=true)時記進 draw-list
+   供影像層在高解析合成層畫出。回傳 true 表示已吃掉一個 CJK(3 bytes)。 */
+static bool lbxfont_handle_cjk(const char *str, int *xp, int y, uint32_t cp, bool record)
+{
+    if (record) {
+        /* 字色取目前字型漸層最高亮端(0x0f);影像層另加黑外框 + 太暗自動提亮確保對比。 */
+        cjk_drawlist_add(*xp, y, cp, lbxfontdata[0x0f], lbxfontdata[0x10]);
+    }
+    *xp += lbxfont_cjk_advance();
+    (void)str;
+    return true;
+}
+
 static int lbxfont_print_char_ret_x(int x, int y, char c)
 {
     return x + lbxfont_plotchar(c, vgabuf_get_xy(x, y));
@@ -203,7 +257,15 @@ static int lbxfont_print_str_do(int x, int y, const char *str, bool change_color
                 break;
             case 0x15:
                 return lbxfont_temp_x;
-            default:
+            default: {
+                uint32_t cp = lbxfont_cjk_at(&str[i]);
+                if (cp) {
+                    int tx = lbxfont_temp_x;
+                    lbxfont_handle_cjk(str, &tx, lbxfont_temp_y, cp, change_color);
+                    lbxfont_temp_x = tx;
+                    i += 2; /* 吃掉 2 個延續位元組(迴圈尾 ++i 吃前導) */
+                    break;
+                }
                 lbxfont_temp_x = lbxfont_print_char_ret_x(lbxfont_temp_x, lbxfont_temp_y, c);
                 if ((w != 0) && (c == ' ')) {
