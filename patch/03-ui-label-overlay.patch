+/* 繁中:畫凸鈕後,取樣鈕面橘色蓋掉烘字英文,再置中印中文(與原版同位置)。 */
+static void new_game_draw_button_cjk(uint8_t *gfx, int x, int y, const char *s)
+{
+    int w = lbxgfx_get_w(gfx);
+    int h = lbxgfx_get_h(gfx);
+    lbxgfx_draw_frame(x, y, gfx);
+    /* 取樣鈕面橘色:避開烘字(中央)與凸邊,取上方 1/4 高處。 */
+    uint8_t face = *vgabuf_get_xy(x + w / 2, y + h / 4);
+    vgabuf_fill_rect(x + 4, y + 3, x + w - 4, y + h - 3, face);
+    lbxfont_select(0, 5, 0, 0);
+    /* 垂直置中:print 的 y 為頂端,glyph 約 12 邏輯高,行中心對齊鈕中心。 */
+    lbxfont_print_str_center(x + w / 2, y + h / 2 - 2, s);
+}
