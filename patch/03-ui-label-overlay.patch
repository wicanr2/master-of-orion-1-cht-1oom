+/* 繁中:在按鈕圖上蓋掉烘字英文(取樣鈕面色填中段)後置中印中文。 */
+static void new_game_draw_button_cjk(uint8_t *gfx, int x, int y, const char *s)
+{
+    int w = lbxgfx_get_w(gfx);
+    int h = lbxgfx_get_h(gfx);
+    lbxgfx_draw_frame(x, y, gfx);
+    uint8_t face = *vgabuf_get_xy(x + 4, y + 2);          /* 取樣鈕面色(上緣) */
+    vgabuf_draw_filled_rect(x + 3, y + h / 2 - 5, x + w - 3, y + h / 2 + 5, face);
+    lbxfont_select(0, 5, 0, 0);
+    lbxfont_print_str_center(x + w / 2, y + h / 2 - 5, s);
+}
