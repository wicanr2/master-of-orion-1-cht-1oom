 static void new_game_draw_cb1(void *vptr)
 {
     struct new_game_data_s *d = vptr;
     vgabuf_erase();
     lbxgfx_draw_frame(0, 0, d->gfx_newgame);
+    /* 繁中化:面板標籤與按鈕文字烘在 LBX 圖裡。取樣 row 中央橘色蓋英文後疊 CJK,
+       對齊原版(左對齊、垂直置中於橘色 bar)。 */
+    {
+        /* row_cy = 各列垂直中心;label 左緣對齊原英文起點 0x6a。 */
+        static const int row_cy[3] = { 0x25, 0x4c, 0x73 };
+        static const char *lbl[3] = { "銀河大小", "難度", "對手" };
+        for (int i = 0; i < 3; ++i) {
+            int cy = row_cy[i];
+            uint8_t orange = *vgabuf_get_xy(0x50, cy); /* row 中央左側乾淨橘色 */
+            vgabuf_fill_rect(0x60, cy - 7, 0xa8, cy + 6, orange); /* 蓋英文(左緣足夠) */
+            lbxfont_select(0, 5, 0, 0);
+            lbxfont_print_str_normal(0x68, cy - 2, lbl[i]); /* glyph 中心 ≈ print_y+2 = cy */
+        }
+    }
+    new_game_draw_button_cjk(d->gfx_optb_cancel, 0x5a, 0x93, "取消");
+    new_game_draw_button_cjk(d->gfx_optb_ok, 0xa1, 0x93, "確定");
 }
 
