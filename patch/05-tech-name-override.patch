diff --git a/src/strtr.c b/src/strtr.c
new file mode 100644
index 0000000..b5edb85
--- /dev/null
+++ b/src/strtr.c
@@ -0,0 +1,151 @@
+#include "config.h"
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <ctype.h>
+#include <dirent.h>
+#include <sys/stat.h>
+
+#include "strtr.h"
+#include "lib.h"
+#include "log.h"
+
+/* 通用英->繁中字串覆蓋:載入 TSV(每行 "english<TAB>中文"),
+   供 LBX 載入的字串(如 research.lbx 科技名)在顯示時翻譯。
+   無 PBX,故以此 override 取代「改散布版權 LBX」。見 docs/adr/0001。 */
+
+struct entry_s {
+    char *en;
+    char *zh;
+};
+
+static struct entry_s *tr = NULL;
+static int tr_num = 0;
+
+static int cmp_entry(const void *a, const void *b)
+{
+    return strcmp(((const struct entry_s *)a)->en, ((const struct entry_s *)b)->en);
+}
+
+static int tr_cap = 0;
+
+/* 原地解碼 \xNN 跳脫為單一位元組(供外交/新聞訊息的 token byte >=0x80)。
+   其他內容原樣保留。回傳解碼後長度。 */
+static size_t strtr_unescape(char *s)
+{
+    char *o = s;
+    for (char *p = s; *p; ) {
+        if (p[0] == '\\' && p[1] == 'x'
+         && isxdigit((unsigned char)p[2]) && isxdigit((unsigned char)p[3])) {
+            char h[3] = { p[2], p[3], 0 };
+            *o++ = (char)(unsigned char)strtol(h, NULL, 16);
+            p += 4;
+        } else {
+            *o++ = *p++;
+        }
+    }
+    *o = '\0';
+    return (size_t)(o - s);
+}
+
+/* 載入單一 TSV 檔(append,不排序)。回傳新增筆數。 */
+static int strtr_load_file(const char *path)
+{
+    FILE *f = fopen(path, "rb");
+    if (!f) {
+        log_warning("strtr: cannot open '%s'\n", path);
+        return 0;
+    }
+    char line[1024];
+    int added = 0;
+    while (fgets(line, sizeof(line), f)) {
+        char *tab = strchr(line, '\t');
+        if (!tab) {
+            continue;
+        }
+        *tab = '\0';
+        char *en = line;
+        char *zh = tab + 1;
+        size_t zl = strlen(zh);
+        while (zl && (zh[zl - 1] == '\n' || zh[zl - 1] == '\r')) {
+            zh[--zl] = '\0';
+        }
+        if (!en[0] || !zh[0]) {
+            continue;
+        }
+        if (tr_num >= tr_cap) {
+            tr_cap = tr_cap ? tr_cap * 2 : 256;
+            tr = lib_realloc(tr, sizeof(struct entry_s) * tr_cap);
+        }
+        strtr_unescape(en);                 /* \xNN -> token byte(外交/新聞) */
+        strtr_unescape(zh);
+        tr[tr_num].en = lib_stralloc(en);
+        tr[tr_num].zh = lib_stralloc(zh);
+        ++tr_num;
+        ++added;
+    }
+    fclose(f);
+    return added;
+}
+
+/* path 為目錄時載入其中所有 *.tsv;為檔案時載入單檔。 */
+bool strtr_init(const char *path)
+{
+    strtr_shutdown();
+    if (!path) {
+        path = getenv("MOO_STR_TR");
+    }
+    if (!path || !path[0]) {
+        return false;
+    }
+    struct stat st;
+    if ((stat(path, &st) == 0) && S_ISDIR(st.st_mode)) {
+        DIR *d = opendir(path);
+        if (d) {
+            struct dirent *e;
+            char fp[1024];
+            while ((e = readdir(d)) != NULL) {
+                const char *nm = e->d_name;
+                size_t l = strlen(nm);
+                /* 只載 *_zh.tsv(譯文檔),避開 *.tsv 英文來源檔 */
+                if (l > 7 && strcmp(nm + l - 7, "_zh.tsv") == 0) {
+                    snprintf(fp, sizeof(fp), "%s/%s", path, nm);
+                    strtr_load_file(fp);
+                }
+            }
+            closedir(d);
+        }
+        log_message("strtr: loaded %d translations from dir '%s'\n", tr_num, path);
+    } else {
+        strtr_load_file(path);
+        log_message("strtr: loaded %d translations from '%s'\n", tr_num, path);
+    }
+    qsort(tr, tr_num, sizeof(struct entry_s), cmp_entry);
+    return tr_num > 0;
+}
+
+void strtr_shutdown(void)
+{
+    if (tr) {
+        for (int i = 0; i < tr_num; ++i) {
+            lib_free(tr[i].en);
+            lib_free(tr[i].zh);
+        }
+        lib_free(tr);
+        tr = NULL;
+    }
+    tr_num = 0;
+    tr_cap = 0;
+}
+
+const char *strtr(const char *en)
+{
+    if (!tr || !en) {
+        return en;
+    }
+    struct entry_s key;
+    key.en = (char *)en;
+    const struct entry_s *r = bsearch(&key, tr, tr_num, sizeof(struct entry_s), cmp_entry);
+    return r ? r->zh : en;
+}
diff --git a/src/strtr.h b/src/strtr.h
new file mode 100644
index 0000000..fdf9128
--- /dev/null
+++ b/src/strtr.h
@@ -0,0 +1,14 @@
+#ifndef INC_1OOM_STRTR_H
+#define INC_1OOM_STRTR_H
+
+#include "types.h"
+
+/* 通用英->繁中字串覆蓋(LBX 載入字串的翻譯層)。見 docs/adr/0001。
+   path 為 NULL 時讀環境變數 MOO_STR_TR。 */
+extern bool strtr_init(const char *path);
+extern void strtr_shutdown(void);
+
+/* 回傳 en 的繁中譯;無對應或未載入則原樣回傳 en。 */
+extern const char *strtr(const char *en);
+
+#endif
