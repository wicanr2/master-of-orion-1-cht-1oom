 #include "comp.h"
 #include "hw.h"
 #include "lbxfont.h"
+#include "lbxgfx.h"
+#include "vgabuf.h"
 #include "mouse.h"
 #include "rnd.h"
 #include "uicursor.h"
@@ -677,3 +680,24 @@ void ui_draw_textbox_2str(const char *str1, const char *str2, int y0)
     }
     lbxfont_print_str_split(x0 + 4, y0 + 4, w - 8, str2, 2);
 }
+
+/* 繁中:在已畫好的烘字按鈕圖上,取樣鈕面色蓋掉原本英文,再置中疊上中文。
+   呼叫端須先 lbxgfx_draw_frame 把按鈕底圖畫進 vgabuf,並把該 t0 物件改成 mousearea
+   (t0 的 gfx 會在 callback 之後重畫,覆蓋掉中文)。 */
+void ui_draw_btn_cjk(const uint8_t *gfx, int x, int y, const char *s)
+{
+    int w = lbxgfx_get_w(gfx);
+    int h = lbxgfx_get_h(gfx);
+    int cjkh, logh;
+    uint8_t face = *vgabuf_get_xy(x + w / 2, y + h / 4);
+    vgabuf_draw_filled_rect(x + 3, y + 2, x + w - 3, y + h - 2, face);
+    /* 依按鈕高度選字級:夠高的鈕用大字型(-> 24px CJK),矮鈕用小字型(14px) */
+    if (h >= 15) {
+        lbxfont_select_set_12_4(5, 0xf, 0, 0);
+    } else {
+        lbxfont_select(0, 0xf, 0, 0);
+    }
+    cjkh = cjkfont_size_for(lbxfont_get_height());  /* CJK 點陣高(composite px):14/16/24 */
+    logh = cjkh / 2;                                 /* 對應 game 邏輯字高 */
+    lbxfont_print_str_center(x + w / 2, y + (h - logh) / 2 + 1, s);
+}
