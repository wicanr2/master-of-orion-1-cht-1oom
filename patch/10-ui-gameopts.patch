+/* 繁中:面板烘字標題(Game/Sound/Ok)疊中文 —— 取樣標題框色蓋掉英文後置中印。 */
+static void gameopts_label_cjk(int x0, int y0, int x1, int y1, const char *s)
+{
+    uint8_t face = *vgabuf_get_xy(x0 + 2, y0 + 1);
+    int cjkh, logh;
+    vgabuf_fill_rect(x0, y0, x1, y1, face);
+    if ((y1 - y0) >= 15) {
+        lbxfont_select_set_12_4(5, 0xf, 0, 0);
+    } else {
+        lbxfont_select(0, 0xf, 0, 0);
+    }
+    cjkh = cjkfont_size_for(lbxfont_get_height());
+    logh = cjkh / 2;
+    lbxfont_print_str_center((x0 + x1) / 2, y0 + (y1 - y0 - logh) / 2 + 1, s);
+}
+
 static void gameopts_draw_cb(void *vptr)
 {
     struct gameopts_data_s *d = vptr;
     vgabuf_erase();
     lbxgfx_draw_frame(0, 0, d->gfx_game);
+
+    /* 烘字按鈕:儲存 / 載入 / 離開 */
+    lbxgfx_set_new_frame(d->gfx_save, 1);
+    lbxgfx_draw_frame(115, 56, d->gfx_save);
+    ui_draw_btn_cjk(d->gfx_save, 115, 56, "儲存");
+    lbxgfx_set_new_frame(d->gfx_load, 1);
+    lbxgfx_draw_frame(115, 81, d->gfx_load);
+    ui_draw_btn_cjk(d->gfx_load, 115, 81, "載入");
+    lbxgfx_set_new_frame(d->gfx_quit, 1);
+    lbxgfx_draw_frame(115, 106, d->gfx_quit);
+    ui_draw_btn_cjk(d->gfx_quit, 115, 106, "離開");
+
+    /* 音效模式 toggle(選中態 frame 1):靜音 / 音效 / 音樂 */
+    if (d->fxmusic == 0) { lbxgfx_set_new_frame(d->gfx_silent, 1); } else { lbxgfx_set_frame_0(d->gfx_silent); }
+    lbxgfx_draw_frame(210, 56, d->gfx_silent);
+    ui_draw_btn_cjk(d->gfx_silent, 210, 56, "靜音");
+    if (d->fxmusic == 1) { lbxgfx_set_new_frame(d->gfx_fx, 1); } else { lbxgfx_set_frame_0(d->gfx_fx); }
+    lbxgfx_draw_frame(210, 81, d->gfx_fx);
+    ui_draw_btn_cjk(d->gfx_fx, 210, 81, "音效");
+    if (d->fxmusic == 2) { lbxgfx_set_new_frame(d->gfx_music, 1); } else { lbxgfx_set_frame_0(d->gfx_music); }
+    lbxgfx_draw_frame(210, 106, d->gfx_music);
+    ui_draw_btn_cjk(d->gfx_music, 210, 106, "音樂");
+
+    /* 面板烘字標題:遊戲 / 聲音 / 確定(Ok) */
+    gameopts_label_cjk(126, 36, 186, 50, "遊戲");
+    gameopts_label_cjk(206, 36, 263, 50, "聲音");
+    gameopts_label_cjk(173, 134, 226, 150, "確定");
 }
 
