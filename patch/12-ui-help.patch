+/* 繁中:CJK 走 overlay draw-list,每次 flip 後清空;help 原本只畫一次,故 CJK
+   會在 input_wait 期間的重複 flip 後消失。改為每幀重畫的 callback(重加 CJK 到
+   draw-list),CJK 才能持續顯示。 */
+struct help_cb_data_s {
+    uint8_t *helplbx;
+    int help_index;
+    uint8_t ctbl[5], c0, c1, c3, c4, c5, c8;
+};
+
+static void help_draw_cb(void *vptr)
+{
+    struct help_cb_data_s *d = vptr;
+    const uint8_t *p = &(d->helplbx[4 + HELP_ITEM_SIZE * d->help_index]);
+    vgabuf_copy_back_from_page3();
+    lbxfont_select(0, 0, 0, 0);
+    lbxfont_set_gap_h(3);
+    lbxfont_set_14_24(d->c1, d->c0);
+    ui_help_draw(strtr((const char *)&p[HELP_OFFS_STR0]), strtr((const char *)&p[HELP_OFFS_STR1]),
+                GET_LE_16(&p[HELP_OFFS_XTBL]), GET_LE_16(&p[HELP_OFFS_YTBL]),
+                GET_LE_16(&p[HELP_OFFS_WTBL]), GET_LE_16(&p[HELP_OFFS_LTTBL]),
+                GET_LE_16(&p[HELP_OFFS_LXTBL]), GET_LE_16(&p[HELP_OFFS_LYTBL]),
+                d->ctbl, d->c3, d->c4, d->c5, d->c3, d->c4, d->c8, d->c0, 1);
+    if (GET_LE_16(&p[HELP_OFFS_10]) < 3) {
+        for (int i = 0; i < 9; ++i) {
+            ui_help_draw("", strtr((const char *)&p[HELP_OFFS_STBL + i * HELP_STBL_SIZE]),
+                GET_LE_16(&p[HELP_OFFS_XTBL + i * 2 + 4]), GET_LE_16(&p[HELP_OFFS_YTBL + i * 2 + 4]),
+                GET_LE_16(&p[HELP_OFFS_WTBL + i * 2 + 4]), GET_LE_16(&p[HELP_OFFS_LTTBL + i * 2 + 4]),
+                GET_LE_16(&p[HELP_OFFS_LXTBL + i * 2 + 4]), GET_LE_16(&p[HELP_OFFS_LYTBL + i * 2 + 4]),
+                d->ctbl, d->c3, d->c4, d->c5, d->c3, d->c4, d->c8, d->c0, i + 10040);
+        }
+    } else {
+        ui_help_draw(strtr((const char *)&p[HELP_OFFS_STR2]), strtr((const char *)&p[HELP_OFFS_STR3]),
+                GET_LE_16(&p[HELP_OFFS_XTBL + 2]), GET_LE_16(&p[HELP_OFFS_YTBL + 2]),
+                GET_LE_16(&p[HELP_OFFS_WTBL + 2]), GET_LE_16(&p[HELP_OFFS_LTTBL + 2]),
+                GET_LE_16(&p[HELP_OFFS_LXTBL + 2]), GET_LE_16(&p[HELP_OFFS_LYTBL + 2]),
+                d->ctbl, d->c3, d->c4, d->c5, d->c3, d->c4, d->c8, d->c0, 10040);
+    }
+}
